# Docker Compose test overlay — committed test credentials (not a operator sample).

POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=test_only

ENV=test
PORT=8014

WORKOS_CLIENT_ID=client_test_dummy_id
WORKOS_API_KEY=sk_test_dummy_key
WORKOS_COOKIE_PASSWORD=dummy_cookie_password_32_chars_long_xxxxxx
CSRF_SECRET_KEY=dummy_csrf_secret
FRONTEND_URL=http://localhost:5173
WORKOS_REDIRECT_URI=http://localhost:8014/callback

JWT_PRIVATE_KEY_PEM=DEFAULT_PRIVATE_KEY
JWT_PUBLIC_KEY_PEM=DEFAULT_PUBLIC_KEY
JWT_CLAIM_NAMESPACE=neosofia
VALID_ROLES=admin,user
ACCESS_TOKEN_TTL_SECS=900
SERVICE_TOKEN_TTL_SECS=300

MIGRATION_DATABASE_URL=postgresql+psycopg://auth:test_only@auth-postgres:5432/auth
APP_DATABASE_URL=postgresql+psycopg://app:test_only_app@auth-postgres:5432/auth
