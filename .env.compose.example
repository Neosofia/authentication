# Docker Compose stack — used by docker-compose.yml (auth-postgres service hostname)
# Copy to .env to override; run scripts/setup-env.py to generate secrets first.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8014
ENV=development

# ── WorkOS ────────────────────────────────────────────────────────────────────
WORKOS_CLIENT_ID=client_YOUR_WORKOS_CLIENT_ID
WORKOS_API_KEY=sk_test_YOUR_WORKOS_API_KEY
WORKOS_COOKIE_PASSWORD=
CSRF_SECRET_KEY=
FRONTEND_URL=http://localhost:5173
WORKOS_REDIRECT_URI=http://localhost:8014/callback

# ── Platform JWT (RS256) ──────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_CLAIM_NAMESPACE=neosofia
VALID_ROLES=clinician,org-clinician,member
ACCESS_TOKEN_TTL_SECS=900
SERVICE_TOKEN_TTL_SECS=300

# Passwords generated by scripts/setup-env.py (copy output to .env for compose overrides)
MIGRATION_DATABASE_URL=postgresql+psycopg://auth:@auth-postgres:5432/auth
APP_DATABASE_URL=postgresql+psycopg://app:@auth-postgres:5432/auth
