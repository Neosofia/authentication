# Authentication Service — copy to .env and fill in real values

# ── Server ────────────────────────────────────────────────────────────────────
# Port for this service (monorepo naming: AUTHENTICATION_PORT for clarity)
# Default: 8014
AUTHENTICATION_PORT=8014

# Runtime environment: "development" enables Flask debug mode and http-only cookies
# Default: "production" (debug mode disabled)
# Set to "development" to enable Werkzeug interactive debugger during local development
ENV=development

# ── WorkOS ────────────────────────────────────────────────────────────────────
# From: WorkOS Dashboard → API Keys
WORKOS_CLIENT_ID=client_YOUR_WORKOS_CLIENT_ID
WORKOS_API_KEY=sk_test_YOUR_WORKOS_API_KEY

# Must be a 32-byte url-safe base64 string (Fernet key). Run scripts/setup-env.sh to generate.
# Do NOT use openssl rand -hex — hex is not valid base64 and will cause a redirect loop at login.
WORKOS_COOKIE_PASSWORD=

# ── Flask ─────────────────────────────────────────────────────────────────────
# Run scripts/setup-env.sh to generate this automatically.
CSRF_SECRET_KEY=

# Where WorkOS should redirect after authentication
# This is a testing redirect URI for local development; in production, it should 
# be your deployed callback URL.
WORKOS_REDIRECT_URI=http://localhost:8014/callback

# ── Platform JWT (RS256) ──────────────────────────────────────────────────────
# Run scripts/setup-env.sh — it generates the keypair and writes these values
# correctly. Do not edit by hand; PEM keys must be single-line with literal \n.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# Issuer claim embedded in every platform JWT.
# Used by all consuming services to verify token authenticity.
# In tests, this is overridden to https://auth.test.local for isolation.
JWT_ISSUER=https://auth.neosofia.local

# Claim namespace prefix for platform-specific JWT claims (e.g. "{ns}:token_type").
# Forks should set this to their own org/product name. Default: neosofia
JWT_CLAIM_NAMESPACE=neosofia

# Comma-separated list of WorkOS org membership roles this service will accept.
# Required — the service will refuse to start if unset or empty.
# Forks: replace with your own WorkOS role slugs.
VALID_ROLES=clinician,org-clinician,member

# Platform JWT lifetime in seconds (max 900 = 15 minutes per FR-001)
ACCESS_TOKEN_TTL_SECS=900

# Machine JWT lifetime in seconds
MACHINE_TOKEN_TTL_SECS=300

# ── Database (required for machine credentials only) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://auth:dev_only@localhost:5014/auth
