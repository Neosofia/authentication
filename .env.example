# Authentication Service — copy to .env and fill in real values

# ── Server ────────────────────────────────────────────────────────────────────
# Port the service listens on. Railway injects PORT automatically; set explicitly for local dev.
PORT=8014

# Runtime environment: "development" enables Flask debug mode and http-only cookies
# Default: "production" (debug mode disabled)
# Set to "development" to enable Werkzeug interactive debugger during local development
ENV=development

# ── WorkOS ────────────────────────────────────────────────────────────────────
# From: WorkOS Dashboard → API Keys
WORKOS_CLIENT_ID=client_YOUR_WORKOS_CLIENT_ID
WORKOS_API_KEY=sk_test_YOUR_WORKOS_API_KEY

# Must be a 32-byte url-safe base64 string (Fernet key). Run scripts/setup-env.py to generate.
# Do NOT use openssl rand -hex — hex is not valid base64 and will cause a redirect loop at login.
WORKOS_COOKIE_PASSWORD=

# ── Flask session signing (OAuth state + PKCE verifier) ───────────────────────
# Run scripts/setup-env.py to generate this automatically.
CSRF_SECRET_KEY=

# Where the Authentication service should redirect users after a successful WorkOS login/logout.
# Usually the public URL of your UI service. Used by /routes/auth.py.
FRONTEND_URL=http://localhost:5173

# Where WorkOS should redirect after authentication
# This is a testing redirect URI for local development; in production, it should 
# be your deployed callback URL.
WORKOS_REDIRECT_URI=http://localhost:8014/callback

# ── Platform JWT (RS256) ──────────────────────────────────────────────────────
# Run scripts/setup-env.py — it generates the keypair and writes these values
# correctly. Do not edit by hand; PEM keys must be single-line with literal \n.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# Optional: previous public key during JWT key rotation overlap (see OPERATIONS.md).
# JWT_PREVIOUS_PUBLIC_KEY_PEM=

# Claim namespace prefix for platform-specific JWT claims (e.g. "{ns}:token_type").
# Forks should set this to their own org/product name. Default: neosofia
JWT_CLAIM_NAMESPACE=neosofia

# Comma-separated Tier-1 IdP actor classes (WorkOS org membership roles) this service accepts.
# Required — the service will refuse to start if unset or empty.
VALID_ROLES=operator,clinician,patient

# Platform JWT lifetime in seconds (max 900 = 15 minutes per FR-001)
ACCESS_TOKEN_TTL_SECS=900

# Service JWT lifetime in seconds
SERVICE_TOKEN_TTL_SECS=300

# ── Database ──────────────────────────────────────────────────────────────────
# Two roles are always required:
#   MIGRATION_DATABASE_URL — superuser (DDL, audit schema, CREATE ROLE app)
#   APP_DATABASE_URL       — restricted app role (runtime SELECT/INSERT/UPDATE only)
MIGRATION_DATABASE_URL=postgresql+psycopg://auth:@localhost:5014/auth
# Passwords generated by scripts/setup-env.py
APP_DATABASE_URL=postgresql+psycopg://app:@localhost:5014/auth

# Docker Compose (auth in-container): run scripts/setup-env.py --for-compose
