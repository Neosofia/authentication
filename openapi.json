{
  "openapi": "3.0.0",
  "info": {
    "title": "Authentication Service API",
    "description": "Authentication, token issuance, and JWT validation for the Neosofia platform. Delegates user authentication to WorkOS; issues RS256-signed JWTs for platform-wide service-to-service and client authentication.",
    "version": "1.0.0",
    "contact": {
      "name": "Neosofia Platform Team"
    },
    "license": {
      "name": "Proprietary"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8014",
      "description": "Local development"
    },
    {
      "url": "https://auth.neosofia.local",
      "description": "Production"
    }
  ],
  "tags": [
    {
      "name": "OAuth2 & Tokens",
      "description": "Token issuance and session management"
    },
    {
      "name": "Validation",
      "description": "JWT validation and user info retrieval"
    },
    {
      "name": "Health",
      "description": "Service health and liveness probes"
    },
    {
      "name": "Services",
      "description": "Platform service registration and credential lifecycle management (operator only)"
    },
    {
      "name": "Tenants",
      "description": "Platform tenant metadata (authentication identity store)"
    },
    {
      "name": "Identity provider",
      "description": "Operator observability for delegated identity-provider sign-in events"
    }
  ],
  "paths": {
    "/api/token": {
      "post": {
        "tags": [
          "OAuth2 & Tokens"
        ],
        "summary": "Issue platform JWT",
        "description": "Issue RS256-signed platform JWT via OAuth2 implicit (session) or client_credentials (Basic auth) grant. Supports both human authentication (via sealed WorkOS session cookie) and service-to-service authentication (via service credentials).",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "title": "Session Grant (Human)",
                    "description": "Implicit grant: no body required, token extracted from wos_session cookie"
                  },
                  {
                    "type": "object",
                    "title": "Client Credentials Grant (Service)",
                    "properties": {
                      "grant_type": {
                        "type": "string",
                        "enum": [
                          "client_credentials"
                        ],
                        "description": "Must be 'client_credentials'"
                      },
                      "audience": {
                        "type": "string",
                        "description": "Requested audience (service name) for the issued token"
                      }
                    },
                    "required": [
                      "grant_type"
                    ]
                  }
                ]
              }
            },
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "title": "Session Grant (Human)",
                    "description": "Implicit grant: no body required, token extracted from wos_session cookie"
                  },
                  {
                    "type": "object",
                    "title": "Client Credentials Grant (Service)",
                    "properties": {
                      "grant_type": {
                        "type": "string",
                        "enum": [
                          "client_credentials"
                        ],
                        "description": "Must be 'client_credentials'"
                      },
                      "audience": {
                        "type": "string",
                        "description": "Requested audience (service name) for the issued token"
                      },
                      "client_id": {
                        "type": "string",
                        "description": "Service client_id (alternative to Authorization: Basic)"
                      },
                      "client_secret": {
                        "type": "string",
                        "description": "Service client_secret (alternative to Authorization: Basic)"
                      }
                    },
                    "required": [
                      "grant_type"
                    ]
                  }
                ]
              }
            }
          }
        },
        "security": [
          {
            "BasicAuth": []
          },
          {
            "SessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Token issued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request (missing grant type, invalid credentials format)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized (invalid credentials, no session)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable (WorkOS, database, or config unavailable)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/tenants/{tenant_uuid}": {
      "get": {
        "tags": [
          "Tenants"
        ],
        "summary": "Get tenant",
        "description": "Returns tenant metadata from the authentication identity store. Operators may read any tenant; other principals may only read their session tenant (`neosofia:tenant_uuid`).",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "tenant_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "uuid",
                    "name",
                    "idp_id"
                  ],
                  "properties": {
                    "uuid": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "name": {
                      "type": "string"
                    },
                    "display_code": {
                      "type": "string",
                      "nullable": true,
                      "description": "Human-facing org shorthand (e.g. site number 1034)"
                    },
                    "idp_id": {
                      "type": "string",
                      "description": "WorkOS organization id"
                    },
                    "type": {
                      "type": "string",
                      "nullable": true,
                      "description": "Org kind: platform, cro, sponsor, site, smo, patient"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Tenant not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/token-inspect": {
      "get": {
        "tags": [
          "Debug"
        ],
        "summary": "Inspect platform JWT claims (debug, development only)",
        "description": "Decode a Bearer JWT and return its claims without validating issuer, audience, or signature. Only available when ENV=development or ENV=test. Returns 404 in all other environments. Rate-limited to 10 requests per minute per IP.",
        "security": [
          {
            "BearerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Token valid, claims returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlatformJWTClaims"
                }
              }
            }
          },
          "400": {
            "description": "Malformed or unparseable JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (10 requests per minute per IP)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not available outside development/test environments",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "x-environments": [
          "development",
          "test"
        ],
        "x-debug-only": true
      }
    },
    "/api/services": {
      "get": {
        "tags": ["Services"],
        "summary": "List platform services",
        "description": "Paginated list of registered services joined with latest credential metadata. Supports search by name, slug, or base_url. Sorted by credential changed_at ascending (oldest rotation first) to surface stale credentials.",
        "security": [{"BearerToken": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1, "minimum": 1}},
          {"name": "page_size", "in": "query", "schema": {"type": "integer", "default": 20, "minimum": 1, "maximum": 100}},
          {"name": "q", "in": "query", "description": "Filter by name, slug, or base_url (case-insensitive substring)", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Paginated service list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {"type": "array", "items": {"$ref": "#/components/schemas/ServiceItem"}},
                    "total": {"type": "integer"},
                    "page": {"type": "integer"},
                    "page_size": {"type": "integer"}
                  }
                }
              }
            }
          },
          "403": {"description": "Forbidden — requires operator role", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "500": {"description": "Database error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "tags": ["Services"],
        "summary": "Register a new platform service",
        "description": "Create a service record and generate its first credential. Returns the plaintext secret exactly once.",
        "security": [{"BearerToken": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "slug", "base_url"],
                "properties": {
                  "name": {"type": "string"},
                  "slug": {"type": "string"},
                  "base_url": {"type": "string", "format": "uri"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Service created — secret returned exactly once",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "uuid": {"type": "string", "format": "uuid"},
                    "name": {"type": "string"},
                    "slug": {"type": "string"},
                    "base_url": {"type": "string"},
                    "client_secret": {"type": "string", "description": "Plaintext secret — returned exactly once"}
                  }
                }
              }
            }
          },
          "400": {"description": "Missing required fields", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "403": {"description": "Forbidden — requires operator role", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "409": {"description": "Name, slug, or base_url already in use", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/services/{slug}": {
      "parameters": [
        {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
      ],
      "get": {
        "tags": ["Services"],
        "summary": "Get service details",
        "security": [{"BearerToken": []}],
        "responses": {
          "200": {"description": "Service details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ServiceItem"}}}},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "404": {"description": "Service not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "put": {
        "tags": ["Services"],
        "summary": "Update service details",
        "description": "Update name, slug, and/or base_url.",
        "security": [{"BearerToken": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "slug": {"type": "string"},
                  "base_url": {"type": "string", "format": "uri"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Updated service", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ServiceItem"}}}},
          "400": {"description": "No updatable fields", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "409": {"description": "Conflict — name/slug/base_url in use", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/services/audits": {
      "get": {
        "tags": ["Services"],
        "summary": "List platform service audits",
        "description": "Returns recent service and credential audit events across the catalog. Operator-only.",
        "security": [{"BearerToken": []}],
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 50, "minimum": 1, "maximum": 100}}
        ],
        "responses": {
          "200": {
            "description": "Recent platform audit events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {"type": "array", "items": {"$ref": "#/components/schemas/CredentialAuditItem"}}
                  }
                }
              }
            }
          },
          "400": {"description": "Invalid query parameters", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "403": {"description": "Forbidden — requires operator role", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "500": {"description": "Database error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/services/{slug}/rotate": {
      "parameters": [
        {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
      ],
      "post": {
        "tags": ["Services"],
        "summary": "Rotate service credential",
        "description": "Atomically deactivate all existing credentials and generate a new one. The new plaintext secret is returned exactly once.",
        "security": [{"BearerToken": []}],
        "responses": {
          "200": {
            "description": "New credential issued — secret returned exactly once",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "slug": {"type": "string"},
                    "client_secret": {"type": "string", "description": "New plaintext secret — returned exactly once"}
                  }
                }
              }
            }
          },
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/services/{slug}/audits": {
      "parameters": [
        {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
      ],
      "get": {
        "tags": ["Services"],
        "summary": "Get credential audit history for a service",
        "security": [{"BearerToken": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1, "minimum": 1}},
          {"name": "page_size", "in": "query", "schema": {"type": "integer", "default": 20, "minimum": 1, "maximum": 100}}
        ],
        "responses": {
          "200": {
            "description": "Paginated audit history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "service_uuid": {"type": "string", "format": "uuid"},
                    "slug": {"type": "string"},
                    "total": {"type": "integer"},
                    "page": {"type": "integer"},
                    "page_size": {"type": "integer"},
                    "items": {"type": "array", "items": {"$ref": "#/components/schemas/CredentialAuditItem"}}
                  }
                }
              }
            }
          },
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/idp/failed-authentications": {
      "get": {
        "tags": ["Identity provider"],
        "summary": "List failed identity-provider sign-in attempts",
        "description": "Returns recent failed authentication events from the configured identity provider (cursor pagination). Operator-only; requires Tier-1 operator actor.",
        "security": [{"BearerToken": []}],
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 25, "minimum": 1, "maximum": 100}},
          {"name": "before", "in": "query", "schema": {"type": "string"}, "description": "Provider event id cursor for newer page"},
          {"name": "after", "in": "query", "schema": {"type": "string"}, "description": "Provider event id cursor for older page"}
        ],
        "responses": {
          "200": {
            "description": "Failed authentication events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {"type": "array", "items": {"$ref": "#/components/schemas/FailedAuthenticationEvent"}},
                    "limit": {"type": "integer"},
                    "before": {"type": "string", "nullable": true},
                    "after": {"type": "string", "nullable": true}
                  }
                }
              }
            }
          },
          "400": {"description": "Invalid pagination", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "403": {"description": "Forbidden — requires operator actor", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "501": {"description": "Identity provider does not expose this feed", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "503": {"description": "Identity provider unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Liveness probe",
        "description": "Check service health by executing SELECT 1 against PostgreSQL with 5-second timeout. Used by Kubernetes probes and load balancers.",
        "responses": {
          "200": {
            "description": "Service healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "version"
                  ],
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok",
                        "degraded"
                      ]
                    },
                    "version": {
                      "type": "string",
                      "description": "Service semver from pyproject at install/build time."
                    },
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Service unhealthy (database unavailable)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "version"
                  ],
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "error"
                      ]
                    },
                    "version": {
                      "type": "string",
                      "description": "Service semver from pyproject at install/build time."
                    },
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/jwks.json": {
      "get": {
        "tags": [
          "Validation"
        ],
        "summary": "Get JWT signing public keys",
        "description": "Publish JWT signing public key in JWKS format (RFC 7517). 1-hour cache; used by other services to validate platform JWTs without calling back to auth service. Enables stateless, distributed JWT validation (Constitution \u00a7VII).",
        "responses": {
          "200": {
            "description": "JWKS set with public keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "keys": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "kty": {
                            "type": "string",
                            "enum": [
                              "RSA"
                            ]
                          },
                          "use": {
                            "type": "string",
                            "enum": [
                              "sig"
                            ]
                          },
                          "kid": {
                            "type": "string"
                          },
                          "n": {
                            "type": "string",
                            "description": "RSA modulus (base64url)"
                          },
                          "e": {
                            "type": "string",
                            "description": "RSA exponent (base64url)"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "title": "Token Response",
        "description": "Successful token issuance response",
        "required": [
          "access_token",
          "token_type",
          "expires_in"
        ],
        "properties": {
          "access_token": {
            "type": "string",
            "description": "RS256-signed JWT token",
            "minLength": 50
          },
          "token_type": {
            "type": "string",
            "enum": [
              "Bearer"
            ],
            "description": "Always 'Bearer' per RFC 6750"
          },
          "expires_in": {
            "type": "integer",
            "minimum": 1,
            "description": "Token TTL in seconds"
          }
        }
      },
      "PlatformJWTClaims": {
        "type": "object",
        "title": "Platform JWT Claims",
        "description": "Standard and custom claims in platform JWT",
        "required": [
          "sub",
          "iat",
          "exp",
          "jti",
          "neosofia:token_type",
          "neosofia:token_version"
        ],
        "properties": {
          "sub": {
            "type": "string",
            "description": "Subject (user ID or service name)"
          },
          "iat": {
            "type": "integer",
            "description": "Issued at (Unix timestamp)"
          },
          "exp": {
            "type": "integer",
            "description": "Expiration time (Unix timestamp)"
          },
          "jti": {
            "type": "string",
            "description": "JWT ID (unique identifier)"
          },
          "azp": {
            "type": "string",
            "description": "Authorized party (RFC 7519); present on service tokens only, set to the client_id of the service credential"
          },
          "neosofia:token_type": {
            "type": "string",
            "enum": [
              "human",
              "service"
            ],
            "description": "Token principal class: 'human' for user sessions, 'service' for service-to-service credentials"
          },
          "neosofia:token_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Claim schema version; consumers must reject tokens whose version they do not support"
          },
          "neosofia:actors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tier-1 actor classes (operator, clinician, patient)"
          },
          "neosofia:roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tier-2 role short names within neosofia:tenant_type (e.g. admin, audit); human tokens only"
          },
          "neosofia:tenant_type": {
            "type": "string",
            "description": "Organisation kind (platform, cro, sponsor, site, smo, patient); omitted when unset on tenant row"
          },
          "neosofia:tenant_uuid": {
            "type": "string",
            "description": "Platform tenant UUID (absent for service tokens)"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "title": "Error Response",
        "description": "Standard error response format",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error code (e.g., 'invalid_grant', 'unauthorized')"
          },
          "error_description": {
            "type": "string",
            "description": "Optional human-readable error details"
          }
        }
      },
      "ServiceItem": {
        "type": "object",
        "title": "Service Item",
        "properties": {
          "uuid": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "slug": {"type": "string"},
          "base_url": {"type": "string"},
          "credential_uuid": {"type": "string", "format": "uuid", "nullable": true},
          "credential_changed_at": {"type": "string", "format": "date-time", "nullable": true},
          "days_since_rotation": {"type": "integer", "nullable": true}
        }
      },
      "CredentialAuditItem": {
        "type": "object",
        "title": "Credential Audit Item",
        "properties": {
          "history_uuid": {"type": "string", "format": "uuid"},
          "credential_uuid": {"type": "string", "format": "uuid", "nullable": true},
          "changed_at": {"type": "string", "format": "date-time"},
          "changed_by_uuid": {"type": "string", "format": "uuid"},
          "changed_by_type": {"type": "integer"},
          "change_type": {"type": "integer"}
        }
      },
      "FailedAuthenticationEvent": {
        "type": "object",
        "title": "Failed authentication event",
        "properties": {
          "id": {"type": "string", "description": "Identity-provider event id"},
          "occurred_at": {"type": "string", "format": "date-time"},
          "method": {"type": "string", "description": "Sign-in method (password, oauth, sso, magic_auth, mfa, email_verification)"},
          "status": {"type": "string", "enum": ["failed"]},
          "idp_user_id": {"type": "string", "nullable": true},
          "email": {"type": "string", "format": "email", "nullable": true},
          "error_code": {"type": "string", "nullable": true},
          "error_message": {"type": "string", "nullable": true},
          "ip_address": {"type": "string", "nullable": true}
        }
      }
    },
    "securitySchemes": {
      "BearerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "RS256-signed platform JWT in Authorization header"
      },
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Base64-encoded client_id:client_secret for service credentials grant"
      },
      "SessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "wos_session",
        "description": "Sealed WorkOS session cookie (HTTPOnly, Secure)"
      }
    }
  }
}
