# Local state/plan artifacts — never commit
*.tfstate
*.tfstate.*
*.tfplan
.terraform/
.terraform.lock.hcl

# Per-user tfvars
terraform.tfvars
*.auto.tfvars

# Backend configs are generated by the bootstrap module's outputs; regenerate
# with `tofu output backend_config_<env>` rather than committing.
envs/*/backend.conf
