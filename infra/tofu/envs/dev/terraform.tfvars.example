# Example tfvars for dev (CT 120). Copy to terraform.tfvars and fill in.
# DO NOT commit terraform.tfvars — it holds your WorkOS API key.

proxmox_endpoint    = "https://192.168.3.205:8006/api2/json"
proxmox_ssh_host    = "192.168.3.205"
proxmox_node        = "pve"
ct_template_file_id = "local:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"

# Fetch these from the WorkOS dashboard (dev/sandbox project).
workos_api_key   = "sk_test_REPLACE_ME"
workos_client_id = "client_REPLACE_ME"

# Absolute path to the repo root on your machine (used for docker build).
repo_root = "/Users/you/projects/pdc"
